# ============================================================
# Hospital Management System — Server Environment Configuration
# ============================================================
# Copy this file as .env and fill in the values

# ---- Server ----
NODE_ENV=development
PORT=4000

# ---- PostgreSQL (Neon) ----
DATABASE_URL=postgresql://user:password@host:5432/hms_db?sslmode=require
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- JWT ----
JWT_ACCESS_SECRET=replace-with-strong-random-secret-min-64-chars
JWT_REFRESH_SECRET=replace-with-different-strong-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ---- Security ----
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- CORS ----
CORS_ORIGIN=http://localhost:3000
